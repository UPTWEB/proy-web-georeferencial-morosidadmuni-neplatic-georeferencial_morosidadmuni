# Database Configuration - Remote PostgreSQL
DB_HOST=tu-servidor-postgres.ejemplo.com
DB_PORT=5432
DB_NAME=neplatic
DB_USER=usuario_neplatic
DB_PASSWORD=tu_password_seguro
DB_SCHEMA=neplatic

# Redis Configuration - Message Broker
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CHANNEL=neplatic.rutas

# Web API Configuration - Sync Target
WEB_API_BASE_URL=http://localhost:8000
WEB_API_TOKEN=tu_token_api
DEVICE_ID=DESKTOP-NEPLATIC-01

# Optional settings
SQL_ECHO=false
